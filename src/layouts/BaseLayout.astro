        <a href="/services/" class="text-forest-100 hover:text-white">Services</a>
        <a href="/articles/" class="text-forest-100 hover:text-white">Articles</a>
        <a href="/tools/pump-reminder/" class="bg-accent-500 hover:bg-accent-600 text-white px-3 py-1.5 rounded font-semibold text-xs uppercase tracking-wide">Pump Reminder</a>
      </nav>
      <!-- Mobile nav toggle (JS-free visible links) -->
      <details class="md:hidden relative">
        <summary class="list-none cursor-pointer p-2 rounded hover:bg-forest-600">
