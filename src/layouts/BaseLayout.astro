            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </summary>
        <div class="absolute right-0 top-full mt-1 w-52 bg-forest-800 rounded shadow-lg py-2 z-50">
          <a href="/directory/" class="block px-4 py-2 text-forest-100 hover:bg-forest-700 hover:text-white text-sm">Find a Contractor</a>
          <a href="/towns/" class="block px-4 py-2 text-forest-100 hover:bg-forest-700 hover:text-white text-sm">Towns</a>
          <a href="/services/" class="block px-4 py-2 text-forest-100 hover:bg-forest-700 hover:text-white text-sm">Services</a>
          <a href="/articles/" class="block px-4 py-2 text-forest-100 hover:bg-forest-700 hover:text-white text-sm">Articles</a>
          <a href="/tools/pump-reminder/" class="block px-4 py-2 text-accent-400 hover:bg-forest-700 font-semibold text-sm">Pump Reminder</a>
        </div>
      </details>
    </div>
  </header>

  <main class="flex-1">
