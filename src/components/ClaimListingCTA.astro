---
interface Props {
  contractorName: string;
}
const { contractorName } = Astro.props;
---

<div class="bg-earth-50 border border-earth-200 rounded-lg p-4 text-sm">
  <p class="font-semibold text-gray-800 mb-1">Is this your business?</p>
  <p class="text-gray-600 mb-3">
    Claim your free listing to add photos, a description, expanded service details, and a verified badge.
  </p>
  <a
    href={`/contact/?reason=claim&business=${encodeURIComponent(contractorName)}`}
    class="inline-block bg-forest-700 hover:bg-forest-800 text-white text-sm font-semibold px-4 py-2 rounded transition-colors"
  >
    Claim {contractorName}
  </a>
</div>
