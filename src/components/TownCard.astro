---
interface Props {
  name: string;
  slug: string;
  hasMunicipalSewer: boolean;
  hasLocalSepticRegs: boolean;
  healthServiceProvider: string;
  contractorCount?: number;
}

const { name, slug, hasMunicipalSewer, hasLocalSepticRegs, healthServiceProvider, contractorCount } = Astro.props;

const providerLabel: Record<string, string> = {
  independent: 'Independent BOH',
  cphs: 'CPHS',
  foothills: 'Foothills Health',
  unknown: '',
};
---

<a href={`/towns/${slug}/`} class="block bg-white border border-gray-200 rounded-lg p-4 hover:border-forest-400 hover:shadow-sm transition-all group">
  <h3 class="font-bold text-forest-700 group-hover:text-forest-900">{name}</h3>
  <div class="flex flex-wrap gap-x-3 gap-y-1 mt-2 text-xs text-gray-500">
    {healthServiceProvider !== 'unknown' && (
      <span>{providerLabel[healthServiceProvider]}</span>
    )}
    {hasMunicipalSewer && <span class="text-blue-600">Partial/Full Sewer</span>}
    {hasLocalSepticRegs && <span class="text-amber-700 font-medium">Local regs apply</span>}
    {contractorCount !== undefined && contractorCount > 0 && (
      <span class="text-forest-600">{contractorCount} contractor{contractorCount !== 1 ? 's' : ''}</span>
    )}
  </div>
</a>
