---
interface Props {
  preselectedTown?: string;
  compact?: boolean;
}

const { preselectedTown, compact = false } = Astro.props;

const towns = [
  'Ashfield','Bernardston','Buckland','Charlemont','Colrain','Conway',
  'Deerfield','Erving','Gill','Greenfield','Hawley','Heath','Leverett',
  'Leyden','Monroe','Montague','New Salem','Northfield','Orange','Rowe',
  'Shelburne','Shutesbury','Sunderland','Warwick','Wendell','Whately',
];

const formId = `pump-form-${Math.random().toString(36).slice(2, 7)}`;
---

<div class={compact ? 'bg-earth-100 rounded-lg p-5 border border-earth-200' : 'bg-forest-50 border border-forest-200 rounded-xl p-6 md:p-8'}>
  {!compact && (
    <h2 class="text-xl font-bold text-forest-800 mb-1">Get a Reminder When It's Time to Pump</h2>
    <p class="text-gray-600 text-sm mb-5">Free. No spam. Just a reminder when your system needs it.</p>
  )}
  {compact && (
    <h3 class="text-base font-bold text-forest-800 mb-3">Free Pump Reminder</h3>
  )}

  <div id={`${formId}-success`} class="hidden bg-forest-50 border border-forest-300 rounded-lg p-4 text-forest-800 text-sm font-medium">
    ✓ You're on the list. We'll remind you when it's time to pump.
  </div>
  <div id={`${formId}-error`} class="hidden bg-red-50 border border-red-200 rounded-lg p-4 text-red-700 text-sm">
    Something went wrong. Please try again or email us directly.
  </div>

  <form
    id={formId}
    class="space-y-3"
    novalidate
  >
    <!-- Mailchimp requires EMAIL (uppercase) -->
    <div>
      <label for={`${formId}-email`} class="block text-sm font-medium text-gray-700 mb-1">Email address <span class="text-red-500">*</span></label>
      <input
        type="email"
        id={`${formId}-email`}
        name="EMAIL"
        required
        placeholder="you@example.com"
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent"
      />
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label for={`${formId}-housesize`} class="block text-sm font-medium text-gray-700 mb-1">Household size <span class="text-red-500">*</span></label>
        <select
          id={`${formId}-housesize`}
          name="HOUSESIZE"
          required
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 bg-white"
        >
          <option value="">Select...</option>
          <option value="1-2 people">1–2 people</option>
          <option value="3-4 people">3–4 people</option>
          <option value="5+ people">5+ people</option>
        </select>
      </div>
      <div>
        <label for={`${formId}-lastpump`} class="block text-sm font-medium text-gray-700 mb-1">Last pumped</label>
        <select
          id={`${formId}-lastpump`}
          name="LASTPUMP"
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 bg-white"
        >
          <option value="">Not sure</option>
          <option value="Under 1 year">Less than 1 year ago</option>
          <option value="1-2 years">1–2 years ago</option>
          <option value="3-4 years">3–4 years ago</option>
          <option value="5+ years">5+ years ago</option>
          <option value="Never / new owner">Never / just bought the house</option>
        </select>
      </div>
    </div>
    <div>
      <label for={`${formId}-town`} class="block text-sm font-medium text-gray-700 mb-1">Your town</label>
      <select
        id={`${formId}-town`}
        name="TOWN"
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 bg-white"
      >
        <option value="">Other / not sure</option>
        {towns.map((t) => (
          <option value={t} selected={t.toLowerCase().replace(' ', '-') === preselectedTown}>{t}</option>
        ))}
      </select>
    </div>
    <button
      type="submit"
      class="w-full bg-accent-500 hover:bg-accent-600 text-white font-bold py-2.5 px-4 rounded transition-colors text-sm"
    >
      Send Me a Reminder
    </button>
  </form>
  <p class="text-xs text-gray-500 mt-3">No spam. Unsubscribe anytime. Your information stays private.</p>
</div>

<script define:vars={{ formId }}>
  const form = document.getElementById(formId);
  const successEl = document.getElementById(`${formId}-success`);
  const errorEl = document.getElementById(`${formId}-error`);
  const submitBtn = form.querySelector('[type="submit"]');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = form.querySelector('[name="EMAIL"]').value.trim();
    if (!email) return;

    const houseSize = form.querySelector('[name="HOUSESIZE"]').value;
    if (!houseSize) {
      form.querySelector('[name="HOUSESIZE"]').focus();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    errorEl.classList.add('hidden');

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          EMAIL: email,
          HOUSESIZE: houseSize,
          LASTPUMP: form.querySelector('[name="LASTPUMP"]').value,
          TOWN: form.querySelector('[name="TOWN"]').value,
        }),
      });

      const data = await res.json();

      if (data.success) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        errorEl.textContent = data.error ?? 'Something went wrong. Please try again.';
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Me a Reminder';
      }
    } catch {
      errorEl.textContent = 'Network error. Please check your connection and try again.';
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Me a Reminder';
    }
  });
</script>
