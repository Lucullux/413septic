---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const url = new URL(Astro.request.url);
const preselectedReason = url.searchParams.get('reason') ?? '';
const preselectedBusiness = url.searchParams.get('business') ?? '';
---

<BaseLayout
  title="Contact 413Septic.com"
  description="Contact 413Septic.com with questions, corrections, listing claims, or advertising inquiries."
>
  <div class="max-w-2xl mx-auto px-4 py-10">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact' },
    ]} />

    <h1 class="text-3xl font-extrabold text-gray-900 mb-6">Contact</h1>

    <!-- Contact form — replace with Netlify forms or equivalent -->
    <form
      name="contact"
      method="POST"
      action="/contact/?submitted=true"
      class="space-y-4 bg-white border border-gray-200 rounded-lg p-6 mb-8"
    >
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
          <input type="text" id="name" name="name" required class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
          <input type="email" id="email" name="email" required class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500" />
        </div>
      </div>

      <div>
        <label for="reason" class="block text-sm font-medium text-gray-700 mb-1">Reason <span class="text-red-500">*</span></label>
        <select id="reason" name="reason" required class="w-full border border-gray-300 rounded px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-forest-500">
          <option value="">Select a reason...</option>
          <option value="general" selected={preselectedReason === '' || preselectedReason === 'general'}>General question</option>
          <option value="claim" selected={preselectedReason === 'claim'}>Claim my listing</option>
          <option value="error">Report an error</option>
          <option value="advertising">Advertising inquiry</option>
        </select>
      </div>

      {preselectedBusiness && (
        <input type="hidden" name="business" value={preselectedBusiness} />
      )}

      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-500">*</span></label>
        <textarea
          id="message"
          name="message"
          rows={5}
          required
          placeholder={preselectedReason === 'claim' ? `I'd like to claim the listing for ${preselectedBusiness}. I'm the owner and can be reached at...` : ''}
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 resize-none"
        ></textarea>
      </div>

      <button type="submit" class="w-full bg-forest-700 hover:bg-forest-800 text-white font-bold py-2.5 rounded transition-colors text-sm">
        Send Message
      </button>
    </form>

    <!-- Claim listing info -->
    <div class="bg-earth-50 border border-earth-200 rounded-lg p-5 text-sm">
      <h2 class="font-bold text-gray-800 mb-2">Claim Your Listing</h2>
      <p class="text-gray-600 mb-3">
        Contractor listings on 413Septic.com are based on publicly available information.
        If this is your business, you can claim it for free to:
      </p>
      <ul class="space-y-1 text-gray-600 list-disc list-inside mb-3">
        <li>Add photos and a business description</li>
        <li>Expand your service list and service area details</li>
        <li>Add your website and contact info</li>
        <li>Get a "Verified" badge on your listing</li>
      </ul>
      <p class="text-gray-500 text-xs">Claiming is free. We verify by calling your listed business number.</p>
    </div>
  </div>
</BaseLayout>
